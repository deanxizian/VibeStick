# VibeStick local configuration example.
# Copy to .env for VibeStick. It is parsed as data and must not be sourced as a shell script.
# Only VIBE_STICK_* and CLAUDE_CODE_OAUTH_TOKEN keys are accepted. Quote values containing whitespace.
# Do not put real secrets in git.
# Empty values mean "use the built-in default" unless a comment says the value is required.

# Optional absolute path to a Python >= 3.11 interpreter.
VIBE_STICK_PYTHON=

# REQUIRED -- fill these.
VIBE_STICK_PROVIDER=auto
# Generate with: openssl rand -hex 32 (32-256 URL-safe characters are accepted).
VIBE_STICK_BRIDGE_TOKEN=
# Set to on only if you want real Claude 5H/7D usage and Claude Code is installed/logged in.
VIBE_STICK_CLAUDE_USAGE=off
# Recommended ASR for China: SiliconFlow, OpenAI-compatible.
# Get a key at the official entry point: https://cloud.siliconflow.cn
VIBE_STICK_ASR_PROVIDER=openai-compatible
VIBE_STICK_ASR_BASE_URL=https://api.siliconflow.cn/v1
VIBE_STICK_ASR_API_KEY=
VIBE_STICK_ASR_MODEL=FunAudioLLM/SenseVoiceSmall

# OPTIONAL -- defaults are fine, leave empty to use defaults.
VIBE_STICK_PROJECT_ROOT=
VIBE_STICK_PROJECT_NAME=
VIBE_STICK_MAX_RECORDING_AUDIO_BYTES=2000000
VIBE_STICK_CLAUDE_USAGE_INTERVAL_SECONDS=300
CLAUDE_CODE_OAUTH_TOKEN=
VIBE_STICK_ASR_LANGUAGE=zh
VIBE_STICK_ASR_TIMEOUT_SECONDS=10
VIBE_STICK_ASR_ATTEMPTS=2

# Optional overseas Groq ASR preset.
# VIBE_STICK_ASR_PROVIDER=groq
# VIBE_STICK_ASR_BASE_URL=https://api.groq.com/openai/v1
# VIBE_STICK_ASR_API_KEY=
# VIBE_STICK_ASR_MODEL=whisper-large-v3-turbo

# Legacy Groq-specific aliases remain supported.
VIBE_STICK_GROQ_API_KEY=
VIBE_STICK_GROQ_MODEL=whisper-large-v3-turbo
VIBE_STICK_GROQ_LANGUAGE=zh

# Optional local ASR command. The command receives the recording session JSON on stdin.
# Quote commands containing arguments, for example: '/path/to/transcribe --model local'
VIBE_STICK_TRANSCRIBE_CMD=
VIBE_STICK_TRANSCRIBE_TIMEOUT_SECONDS=15

# Recording behavior.
VIBE_STICK_RECORDING_USE_MAC_MIC=1
VIBE_STICK_AUTO_ENTER=0
# Advanced external recorder hooks receive session JSON on stdin. They are
# executed by /bin/sh; treat their configured values as trusted local code.
VIBE_STICK_RECORDING_START_CMD=
VIBE_STICK_RECORDING_STOP_CMD=
# Keep synchronous start/stop work within the StickS3 HTTP request budgets.
VIBE_STICK_RECORDING_START_TIMEOUT_SECONDS=2
VIBE_STICK_RECORDING_STOP_TIMEOUT_SECONDS=15
# Delete recording media older than this many days. Set 0 to remove media on the next cleanup.
VIBE_STICK_RECORDING_RETENTION_DAYS=7
# Abandoned StickS3 recording leases are reclaimed after this many seconds (60-600).
VIBE_STICK_RECORDING_LEASE_SECONDS=90
# Store transcript text in recording.json only when explicitly enabled.
VIBE_STICK_STORE_TRANSCRIPTS=0
